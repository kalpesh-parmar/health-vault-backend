APP_NAME=Health Vault
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

DATABASE_URL=postgres://postgres:postgres@localhost:5432/health_vault
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000

JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=health-vault
JWT_AUDIENCE=

MAX_LOGIN_ATTEMPTS=3
OTP_EXPIRY_MINUTES=10
PASSWORD_RESET_WINDOW_MINUTES=15

EMAIL_ENABLED=false
EMAIL_FROM=no-reply@health-vault.local
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
PATIENT_DOCUMENTS_BUCKET=patient-documents
USER_PROFILE_IMAGES_BUCKET=user-profile-images

FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_BASE64=

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
